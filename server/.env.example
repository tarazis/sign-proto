PORT=3001
CLIENT_URL=http://localhost:5173

# Gemini captioning — set to true to enable real Gemini Live sessions (default: false uses mock)
GEMINI_ENABLED=false
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-3.1-flash-live-preview  # Live API: AUDIO output only — captions come via outputAudioTranscription
GEMINI_DEBUG_TEXT_NUDGE_EVERY=8  # periodic nudge to force caption generation in v1
